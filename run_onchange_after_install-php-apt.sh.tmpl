#!/usr/bin/env bash
set -euo pipefail
{{ $wantphp := or (eq .profile "work") .server -}}
{{ if and (eq .chezmoi.osRelease.id "ubuntu") $wantphp -}}
{{ $php := "8.5" -}}

# Host CLI PHP on Ubuntu. php{{ $php }} everywhere (matches solamnia-portal's
# serversideup/php:{{ $php }} container, and is the current release).
#   work   = full Nexus dev stack (26.04 ships php{{ $php }} natively; app runs in
#            Sail/Docker, this is the host CLI php for tooling).
#   server = lean runtime for solamnia-portal `artisan` maintenance (the app itself
#            runs containerised; 24.04 needs the ondrej PPA — see below).
# php is intentionally NOT a mise tool on Ubuntu (see mise/config.toml.tmpl). Re-runs
# when this script changes (chezmoi hashes it); every step is guarded so re-runs on an
# already-provisioned host are no-ops.

{{ if eq .chezmoi.osRelease.versionID "24.04" -}}
# 24.04's default repos carry no modern PHP → add ondrej/php once (26.04 ships
# php{{ $php }} natively, so this step is 24.04-only).
if ! ls /etc/apt/sources.list.d/ondrej-*php* >/dev/null 2>&1; then
  echo "[php] adding ondrej/php PPA (php{{ $php }} not in 24.04 default repos)"
  command -v add-apt-repository >/dev/null 2>&1 || sudo apt install -y software-properties-common
  sudo add-apt-repository -y ppa:ondrej/php
fi
{{ end -}}

# --- Packaged extensions (apt) -------------------------------------------------
PKGS=(
{{ if .work -}}
  php{{ $php }}-cli
  php{{ $php }}-curl php{{ $php }}-mbstring php{{ $php }}-xml php{{ $php }}-zip php{{ $php }}-gd
  php{{ $php }}-intl php{{ $php }}-bcmath php{{ $php }}-gmp php{{ $php }}-sqlite3 php{{ $php }}-soap
  php{{ $php }}-pgsql php{{ $php }}-ldap
  php{{ $php }}-igbinary php{{ $php }}-imagick php{{ $php }}-memcached php{{ $php }}-msgpack
  php{{ $php }}-pcov php{{ $php }}-redis php{{ $php }}-xdebug
{{ else -}}
  php{{ $php }}-cli
  php{{ $php }}-curl php{{ $php }}-mbstring php{{ $php }}-xml php{{ $php }}-zip php{{ $php }}-gd
  php{{ $php }}-intl php{{ $php }}-bcmath php{{ $php }}-gmp php{{ $php }}-sqlite3 php{{ $php }}-mysql
{{ end -}}
)

missing=()
for pkg in "${PKGS[@]}"; do
  dpkg -s "$pkg" >/dev/null 2>&1 || missing+=("$pkg")
done

if [ ${#missing[@]} -eq 0 ]; then
  echo "[php] all ${#PKGS[@]} apt packages already present"
else
  echo "[php] installing ${#missing[@]} missing apt package(s): ${missing[*]}"
  sudo apt update
  sudo apt install -y "${missing[@]}"
fi
{{ if .work }}
# --- pecl-only extensions (opentelemetry, swoole) — work dev stack only ---------
# Not packaged for Ubuntu, so they're compiled with pecl. (install-php-extensions
# refuses to run outside official Docker PHP images, so it can't be used on a host.)
PECL_EXTS=(opentelemetry swoole)
pecl_missing=()
for ext in "${PECL_EXTS[@]}"; do
  php -m 2>/dev/null | grep -qix "$ext" || pecl_missing+=("$ext")
done

if [ ${#pecl_missing[@]} -eq 0 ]; then
  echo "[php] pecl extensions (${PECL_EXTS[*]}) already loaded"
else
  echo "[php] building pecl extension(s): ${pecl_missing[*]}"
  # Toolchain + libs for swoole's optional features (openssl/http2/curl/cares).
  BUILD_PKGS=(
    php8.5-dev php-pear build-essential autoconf pkg-config
    libssl-dev libcurl4-openssl-dev libnghttp2-dev libc-ares-dev
  )
  build_missing=()
  for pkg in "${BUILD_PKGS[@]}"; do
    dpkg -s "$pkg" >/dev/null 2>&1 || build_missing+=("$pkg")
  done
  if [ ${#build_missing[@]} -gt 0 ]; then
    sudo apt update
    sudo apt install -y "${build_missing[@]}"
  fi

  sudo -v                       # cache sudo creds so the piped `sudo pecl` keeps the tty free
  sudo mkdir -p /etc/php/8.5/mods-available

  for ext in "${pecl_missing[@]}"; do
    echo "  → pecl install ${ext}"
    built=0
    # Pipe newlines to accept any prompt defaults; -D pre-answers swoole's build flags.
    if [ "$ext" = "swoole" ]; then
      printf '\n%.0s' {1..20} | sudo pecl install -f \
        -D 'enable-sockets="yes" enable-openssl="yes" enable-http2="yes" enable-swoole-curl="yes" enable-cares="yes"' \
        swoole && built=1
    else
      printf '\n%.0s' {1..20} | sudo pecl install -f "$ext" && built=1
    fi

    if [ "$built" = 1 ]; then
      # Enable for every SAPI the Debian way (mods-available + phpenmod).
      echo "extension=${ext}.so" | sudo tee "/etc/php/8.5/mods-available/${ext}.ini" >/dev/null
      sudo phpenmod -v 8.5 "$ext"
      echo "  ✓ ${ext} installed and enabled"
    else
      echo "  ✗ ${ext} failed to build — apply continues; retry with: sudo pecl install ${ext}" >&2
    fi
  done
fi
{{ end -}}
{{ end -}}
