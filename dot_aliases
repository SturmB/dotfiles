# LSDeluxe

alias ls='lsd'

alias l='ls -l'
alias la='ls -a'
alias ll='ls -la'
alias lt='ls --tree'

# Development Aliases

alias sail='[ -f sail ] && bash sail || bash vendor/bin/sail'

tf() {
    [ -f sail ] && sail artisan test --exclude-testsuite=Integration --filter=$1
}

alias lint='[[ -f sail && -f ./vendor/bin/duster ]] && sail shell -c "./vendor/bin/duster lint"'
alias lint-fix='[[ -f sail && -f ./vendor/bin/duster ]] && sail shell -c "./vendor/bin/duster fix"'
alias pest-cov='[ -f sail ] && sail artisan test --compact --parallel --exclude-testsuite=Integration'
alias pest='[ -f sail ] && sail artisan test --compact --parallel --no-coverage --exclude-testsuite=Integration'
alias pest-int='[ -f sail ] && sail artisan test --compact --parallel --testsuite=Integration'
alias pp='[ -f sail ] && sail pest --compact --parallel --exclude-testsuite=Integration'
alias stan='[[ -f sail && -f ./vendor/bin/phpstan ]] && sail shell -c "./vendor/bin/phpstan analyze"'
alias rector='[[ ./vendor/bin/rector ]] && ./vendor/bin/rector'

alias precommit='rector && lint-fix && lint && stan && pest-cov'
alias precommit-fe='sail npm run format && sail npm run test:run'
