[user]
{{- if eq .profile "work" }}
    name = Chris McGee
    email = cpmcgee@intxlog.com
{{- else }}
    name = Chris McGee
    email = chris@chrismcgee.info
{{- end }}

[init]
    defaultBranch = main

[http]
    lowSpeedLimit = 1000
    lowSpeedTime = 60
    postBuffer = 524288000

[credential "https://github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential

{{ if .personal }}
# Work repos under ~/dev/intxlog use the work identity
[includeIf "gitdir:~/dev/intxlog/"]
    path = ~/.gitconfig-work
{{ end }}
