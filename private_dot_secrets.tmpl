# ~/.secrets — managed by chezmoi; values age-decrypted at apply time. Mode 600.
{{ if .work -}}
export JIRA_API_TOKEN="{{ joinPath .chezmoi.sourceDir ".store/jira.age" | include | decrypt | trim }}"
# GitHub PAT for private intxlog Composer deps (hotshot et al). Read by composer directly,
# and forwarded into Sail / `make setup`'s bootstrap container via `-e COMPOSER_AUTH`.
export COMPOSER_AUTH='{"github-oauth":{"github.com":"{{ joinPath .chezmoi.sourceDir ".store/composer_pat.age" | include | decrypt | trim }}"}}'
{{ end -}}
{{ if .personal -}}
export YNAB_API_KEY="{{ joinPath .chezmoi.sourceDir ".store/ynab.age" | include | decrypt | trim }}"
export OPENROUTER_API_KEY="{{ joinPath .chezmoi.sourceDir ".store/openrouter.age" | include | decrypt | trim }}"
{{ end -}}
