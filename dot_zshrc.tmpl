# ~/.zshrc — managed by chezmoi. Do not edit directly; edit the source template.

# Base shell config: OMZ + plugins + history (distro-aware)
source "${HOME}/.config/zsh/common.zsh"

{{ if eq .chezmoi.osRelease.id "cachyos" -}}
# Arch-only aliases
source "${HOME}/.config/zsh/cachyos.zsh"
{{- end }}

# Aliases (layered: core / work / personal)
source "${HOME}/.aliases"

# Editor
export VISUAL="code --wait"
export EDITOR="$VISUAL"

# PATH
export PATH="$PATH:$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.config/composer/vendor/bin"

# PHP coverage driver
export XDEBUG_MODE=coverage

{{ if .work -}}
# Jira auth type (token comes from ~/.secrets)
export JIRA_AUTH_TYPE=basic
{{- end }}

# Node / tool version managers
{{ if or (eq .profile "work") (eq .profile "stream") -}}
# Work laptop / stream PC: mise only (covers Node + PHP); nvm dropped
export PATH="$HOME/.local/share/mise/shims:$PATH"
command -v mise >/dev/null && eval "$(mise activate zsh)"
{{- else if eq .profile "personal" -}}
# Personal workstation: nvm + mise (unchanged for now)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
export PATH="$HOME/.local/share/mise/shims:$PATH"
command -v mise >/dev/null && eval "$(mise activate zsh)"
{{- end }}
{{/* server profile: no node/version managers */}}

# Lerd shims (php/composer/artisan → exec `lerd …` in-container).
# MUST be prepended AFTER the mise block so it wins over mise's host PHP — otherwise
# bare `php artisan migrate` runs host PHP and can't resolve Podman names like `lerd-postgres`.
[ -d "$HOME/.local/share/lerd/bin" ] && export PATH="$HOME/.local/share/lerd/bin:$PATH"

# fzf
export FZF_BASE="/usr/share/fzf"

# Secrets: sourced from ~/.zshenv now, so they reach non-interactive shells too.

# Completions
autoload -Uz compinit && compinit

# Prompt
command -v starship >/dev/null && eval "$(starship init zsh)"

# Syntax highlighting MUST be sourced last among ZLE-wrapping plugins
{{ if eq .chezmoi.osRelease.id "cachyos" -}}
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{- else -}}
source "$HOME/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
{{- end }}

# zoxide (cd replacement) — initialized last so its precmd/chpwd hook is the
# final one registered, the correct ordering for reliable directory tracking.
# Safe to run after syntax-highlighting: zoxide defines `cd`/`z` functions and a
# chpwd hook only, it does not wrap ZLE widgets.
# (zoxide's doctor self-check is silenced via _ZO_DOCTOR=0 in ~/.zshenv, which
# also covers non-interactive snapshot shells that never source this file.)
command -v zoxide >/dev/null && eval "$(zoxide init --cmd cd zsh)"
